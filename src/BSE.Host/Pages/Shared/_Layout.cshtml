<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(ViewData["Title"] != null ? $"{ViewData["Title"]} — BSE" : "BSE System")</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
          integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
          crossorigin="anonymous" />
    <link rel="stylesheet" href="/css/bse.css" />
</head>
<body>
    <header class="navbar navbar-dark bg-dark">
        <div class="container-fluid">
            <a class="navbar-brand fw-bold" asp-page="/Home">BSE System</a>
            <div class="d-flex align-items-center gap-3">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <span class="text-white-50 small">@User.Identity.Name</span>
                    <a class="btn btn-outline-light btn-sm" asp-page="/Account/Logout">Sign out</a>
                }
            </div>
        </div>
    </header>

    <div class="container-fluid">
        <div class="row">
            <nav class="col-md-2 d-none d-md-block bg-light sidebar py-3 border-end" style="min-height:calc(100vh - 56px)">
                <ul class="nav flex-column">
                    <li class="nav-item">
                        <a class="nav-link" asp-page="/Home">Home</a>
                    </li>
                    <li class="nav-item mt-2">
                        <span class="nav-link fw-semibold text-secondary small text-uppercase">Search</span>
                        <ul class="nav flex-column ms-2">
                            <li><a class="nav-link py-1" asp-page="/Search/Cases">Cases</a></li>
                            <li><a class="nav-link py-1" asp-page="/Search/Farms">Farms</a></li>
                            <li><a class="nav-link py-1" asp-page="/Search/Outstanding">Outstanding</a></li>
                            <li><a class="nav-link py-1" asp-page="/Search/RelatedAnimals">Related Animals</a></li>
                        </ul>
                    </li>
                    <li class="nav-item mt-2">
                        <span class="nav-link fw-semibold text-secondary small text-uppercase">Case Entry</span>
                        <ul class="nav flex-column ms-2">
                            <li><a class="nav-link py-1" asp-page="/Case/New">New Case</a></li>
                            <li><a class="nav-link py-1" asp-page="/Case/Lookup">Open Case</a></li>
                        </ul>
                    </li>
                    <li class="nav-item mt-2">
                        <span class="nav-link fw-semibold text-secondary small text-uppercase">Farm</span>
                        <ul class="nav flex-column ms-2">
                            <li><a class="nav-link py-1" asp-page="/Farm/New">New Farm</a></li>
                            <li><a class="nav-link py-1" asp-page="/Farm/Lookup">Open Farm</a></li>
                        </ul>
                    </li>
                    <li class="nav-item mt-2">
                        <span class="nav-link fw-semibold text-secondary small text-uppercase">Casework</span>
                        <ul class="nav flex-column ms-2">
                            <li><a class="nav-link py-1" asp-page="/CaseWork/Menu">Casework Menu</a></li>
                            <li><a class="nav-link py-1" asp-page="/CaseWork/OpenReport">Open Report</a></li>
                            <li><a class="nav-link py-1" asp-page="/CaseWork/ClosedReport">Closed Report</a></li>
                        </ul>
                    </li>
                    <li class="nav-item mt-2">
                        <span class="nav-link fw-semibold text-secondary small text-uppercase">Audit Log</span>
                        <ul class="nav flex-column ms-2">
                            <li><a class="nav-link py-1" asp-page="/AuditLog/ByDate">By Date</a></li>
                            <li><a class="nav-link py-1" asp-page="/AuditLog/ByUser">By User</a></li>
                            <li><a class="nav-link py-1" asp-page="/AuditLog/CaseMoves">Case Moves</a></li>
                            <li><a class="nav-link py-1" asp-page="/AuditLog/CphhChanges">CPHH Changes</a></li>
                            <li><a class="nav-link py-1" asp-page="/AuditLog/NewFarms">New Farms</a></li>
                            <li><a class="nav-link py-1" asp-page="/AuditLog/RbseChanges">RBSE Changes</a></li>
                        </ul>
                    </li>
                    <li class="nav-item mt-2">
                        <span class="nav-link fw-semibold text-secondary small text-uppercase">BSESS</span>
                        <ul class="nav flex-column ms-2">
                            <li><a class="nav-link py-1" asp-page="/Bsess/CheckByRbse">Check by RBSE</a></li>
                            <li><a class="nav-link py-1" asp-page="/Bsess/CheckByDate">Check by Date</a></li>
                        </ul>
                    </li>
                    <li class="nav-item mt-2">
                        <span class="nav-link fw-semibold text-secondary small text-uppercase">Exports</span>
                        <ul class="nav flex-column ms-2">
                            <li><a class="nav-link py-1" asp-page="/AdnsExport/Menu">ADNS Export</a></li>
                            <li><a class="nav-link py-1" asp-page="/OssExport/Menu">OSS Export</a></li>
                        </ul>
                    </li>
                    <li class="nav-item mt-2">
                        <span class="nav-link fw-semibold text-secondary small text-uppercase">Admin</span>
                        <ul class="nav flex-column ms-2">
                            <li><a class="nav-link py-1" asp-page="/Admin/Users">User Maintenance</a></li>
                            <li><a class="nav-link py-1" asp-page="/Admin/PickLists">Pick Lists</a></li>
                        </ul>
                    </li>
                </ul>
            </nav>

            <main class="col-md-10 ms-sm-auto px-4 py-3">
                @if (TempData["SuccessMessage"] is string success)
                {
                    <div class="alert alert-success alert-dismissible" role="alert">
                        @success
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }
                @if (TempData["ErrorMessage"] is string error)
                {
                    <div class="alert alert-danger alert-dismissible" role="alert">
                        @error
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }
                @RenderBody()
            </main>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
            integrity="sha384-YvpcrYf0tY3lHB60NNkmXc4s9bIOgUxi8T/jzmQXD+5MSzVm6i70kXhN3h7oCKR"
            crossorigin="anonymous"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

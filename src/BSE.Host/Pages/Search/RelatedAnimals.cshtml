@page
@model BSE.Host.Pages.Search.RelatedAnimalsModel
@{
    ViewData["Title"] = "Related Animals Search";
}

<h2>Related Animals Search</h2>

<form method="get" class="mb-4">
    <div class="row g-3">
        <div class="col-md-3">
            <label asp-for="Rbse" class="form-label">RBSE</label>
            <input asp-for="Rbse" class="form-control" />
        </div>
        <div class="col-md-3">
            <label asp-for="Name" class="form-label">Name</label>
            <input asp-for="Name" class="form-control" />
        </div>
        <div class="col-md-3">
            <label asp-for="Eartag" class="form-label">Eartag</label>
            <input asp-for="Eartag" class="form-control" />
        </div>
        <div class="col-md-3">
            <label asp-for="RelationType" class="form-label">Relation Type</label>
            <input asp-for="RelationType" class="form-control" />
        </div>
    </div>
    <div class="mt-3">
        <button type="submit" class="btn btn-primary">Search</button>
    </div>
</form>

@if (Model.HasSearched)
{
    <p class="text-muted">@Model.Results.Count result(s).</p>

    @if (Model.Results.Count > 0)
    {
        <div class="table-responsive">
            <table class="table table-sm table-striped">
                <thead class="table-dark">
                    <tr>
                        <th>RBSE</th>
                        <th>Eartag</th>
                        <th>Name</th>
                        <th>Relation Type</th>
                        <th>Relation RBSE</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in Model.Results)
                    {
                        <tr>
                            <td class="bse-rbse">@r.Rbse</td>
                            <td>@r.Eartag</td>
                            <td>@r.RelName</td>
                            <td>@r.RelationType</td>
                            <td class="bse-rbse">@r.RelationRbse</td>
                            <td>
                                <a asp-page="/Case/Details" asp-route-rbse="@r.Rbse"
                                   class="btn btn-sm btn-outline-primary">Open</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
}

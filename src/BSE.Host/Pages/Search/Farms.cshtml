@page
@model BSE.Host.Pages.Search.FarmsModel
@{
    ViewData["Title"] = "Farm Search";
}

<h2>Farm Search</h2>

<form method="get" class="mb-4">
    <div class="row g-3">
        <div class="col-md-3">
            <label asp-for="Filter.Cphh" class="form-label">CPHH</label>
            <input asp-for="Filter.Cphh" class="form-control" placeholder="e.g. 12/345/0001" />
        </div>
        <div class="col-md-3">
            <label asp-for="Filter.OwnerName" class="form-label">Owner Name</label>
            <input asp-for="Filter.OwnerName" class="form-control" />
        </div>
        <div class="col-md-3">
            <label asp-for="Filter.Address" class="form-label">Address</label>
            <input asp-for="Filter.Address" class="form-control" />
        </div>
        <div class="col-md-3">
            <label asp-for="Filter.County" class="form-label">County</label>
            <input asp-for="Filter.County" class="form-control" />
        </div>
        <div class="col-md-3">
            <label asp-for="Filter.Herdmark" class="form-label">Herdmark</label>
            <input asp-for="Filter.Herdmark" class="form-control" />
        </div>
        <div class="col-md-3">
            <div class="form-check mt-4">
                <input asp-for="Filter.IncludeNonGb" class="form-check-input" />
                <label asp-for="Filter.IncludeNonGb" class="form-check-label">Include Non-GB Farms</label>
            </div>
        </div>
    </div>
    <div class="mt-3">
        <button type="submit" class="btn btn-primary">Search</button>
        <a asp-page="/Search/Farms" class="btn btn-outline-secondary ms-2">Clear</a>
    </div>
</form>

@if (Model.Filter.HasSearched)
{
    <p class="text-muted">@Model.Filter.Results.Count result(s) found.</p>

    @if (Model.Filter.Results.Count > 0)
    {
        <div class="table-responsive">
            <table class="table table-sm table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>CPHH</th>
                        <th>Owner Name</th>
                        <th>Address</th>
                        <th>County</th>
                        <th>Herdmark</th>
                        <th>Cases</th>
                        <th>Confirmed</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in Model.Filter.Results)
                    {
                        <tr>
                            <td>@r.Cphh</td>
                            <td>@r.OwnerName</td>
                            <td>@r.Address</td>
                            <td>@r.County</td>
                            <td>@r.Herdmark</td>
                            <td>@r.CasesCount</td>
                            <td>@r.ConfirmedCasesCount</td>
                            <td>
                                <a asp-page="/Farm/Details" asp-route-cphh="@r.Cphh"
                                   class="btn btn-sm btn-outline-primary">Open</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
}

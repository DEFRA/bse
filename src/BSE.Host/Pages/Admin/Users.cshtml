@page
@model UsersModel
@{
    ViewData["Title"] = "User Management";
}

<div class="container-fluid px-4">
    <h1 class="mt-4">User Management</h1>
    <ol class="breadcrumb mb-4">
        <li class="breadcrumb-item"><a asp-page="/Home">Home</a></li>
        <li class="breadcrumb-item active">Users</li>
    </ol>

    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            Users
            <button class="btn btn-sm btn-primary" data-bs-toggle="collapse" data-bs-target="#addUserForm">+ Add User</button>
        </div>
        <div id="addUserForm" class="collapse">
            <div class="card-body border-bottom">
                <form method="post" asp-page-handler="Add">
                    <div class="row g-3">
                        <div class="col-md-3">
                            <label class="form-label">NT Login</label>
                            <input name="NTLogin" class="form-control" required />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">UPN</label>
                            <input name="Upn" type="email" class="form-control" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Display Name</label>
                            <input name="UserName" class="form-control" required />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Email</label>
                            <input name="Email" type="email" class="form-control" />
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">User Group ID</label>
                            <input name="UserGroupId" type="number" class="form-control" value="1" />
                        </div>
                        <div class="col-md-2">
                            <div class="form-check mt-4">
                                <input name="IsActive" type="checkbox" class="form-check-input" checked />
                                <label class="form-check-label">Active</label>
                            </div>
                        </div>
                    </div>
                    <div class="mt-3">
                        <button type="submit" class="btn btn-primary btn-sm">Save User</button>
                    </div>
                </form>
            </div>
        </div>
        <div class="card-body p-0">
            <table class="table table-sm table-hover mb-0">
                <thead class="table-light">
                    <tr><th>ID</th><th>NT Login</th><th>UPN</th><th>Name</th><th>Email</th><th>Group</th><th>Active</th></tr>
                </thead>
                <tbody>
                    @foreach (var u in Model.Users)
                    {
                        <tr>
                            <td>@u.UserId</td>
                            <td>@u.NTLogin</td>
                            <td>@u.Upn</td>
                            <td>@u.UserName</td>
                            <td>@u.Email</td>
                            <td>@u.UserGroup</td>
                            <td>@(u.IsActive ? "✓" : "✗")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

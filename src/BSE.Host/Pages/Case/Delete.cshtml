@page "{rbse}"
@model DeleteModel
@{
    ViewData["Title"] = "Delete Case";
}

<div class="container-fluid px-4">
    <h1 class="mt-4">Delete Case</h1>
    <ol class="breadcrumb mb-4">
        <li class="breadcrumb-item"><a asp-page="/Home">Home</a></li>
        <li class="breadcrumb-item"><a asp-page="/Case/Lookup">Case Lookup</a></li>
        <li class="breadcrumb-item active">Delete</li>
    </ol>

    @if (Model.CaseRecord is not null)
    {
        <div class="alert alert-danger">
            <strong>Warning:</strong> This action cannot be undone.
        </div>

        <div class="card mb-4">
            <div class="card-header">Case @Model.CaseRecord.Rbse</div>
            <div class="card-body">
                <dl class="row">
                    <dt class="col-sm-3">RBSE</dt>
                    <dd class="col-sm-9">@Model.CaseRecord.Rbse</dd>
                    <dt class="col-sm-3">CPHH</dt>
                    <dd class="col-sm-9">@Model.CaseRecord.Cphh</dd>
                    <dt class="col-sm-3">Eartag</dt>
                    <dd class="col-sm-9">@Model.CaseRecord.EartagHerdmark / @Model.CaseRecord.Eartag</dd>
                    <dt class="col-sm-3">Fate</dt>
                    <dd class="col-sm-9">@Model.CaseRecord.Fate</dd>
                </dl>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-danger">@Model.ErrorMessage</div>
        }

        <form method="post">
            <input type="hidden" asp-for="Rbse" />
            <button type="submit" class="btn btn-danger">Confirm Delete</button>
            <a asp-page="/Case/Details" asp-route-rbse="@Model.Rbse" class="btn btn-secondary ms-2">Cancel</a>
        </form>
    }
    else
    {
        <div class="alert alert-warning">Case <strong>@Model.Rbse</strong> not found.</div>
        <a asp-page="/Case/Lookup" class="btn btn-secondary">Back to Lookup</a>
    }
</div>

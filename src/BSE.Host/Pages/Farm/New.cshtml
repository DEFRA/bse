@page
@model BSE.Host.Pages.Farm.NewModel
@{
    ViewData["Title"] = "New Farm";
}

<h2>New Farm</h2>

<form method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
    @await Html.PartialAsync("_FarmFormFields", Model.Farm)
    <div class="mt-3">
        <button type="submit" class="btn btn-success">Save Farm</button>
        <a asp-page="/Home" class="btn btn-outline-secondary ms-2">Cancel</a>
    </div>
</form>

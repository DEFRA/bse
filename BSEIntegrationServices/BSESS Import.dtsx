          SQLTask:Connection="{A7CDF303-176B-44EE-9D24-6C0E23826CB6}"
          SQLTask:SqlStatementSource="CREATE TABLE [dbo].[BSESSImport] (&#xA; [RBSE] [char] (9) COLLATE Latin1_General_CI_AS NOT NULL ,&#xA; [UnformattedRBSE] [varchar] (10) COLLATE Latin1_General_CI_AS NULL ,&#xA; [AnimalIID] [decimal](18, 0) NOT NULL ,&#xA; [Eartag] [varchar] (20) COLLATE Latin1_General_CI_AS NULL ,&#xA; [BirthDate] [datetime] NULL ,&#xA; [TestGroupDerivedSurvey] [varchar] (4) COLLATE Latin1_General_CI_AS NULL ,&#xA; [TestGroupName] [varchar] (50) COLLATE Latin1_General_CI_AS NULL ,&#xA; [FinalResultID] [tinyint] NULL ,&#xA; [FinalResultName] [varchar] (25) COLLATE Latin1_General_CI_AS NULL ,&#xA; [NotificationDate] [smalldatetime] NULL ,&#xA; [BarCode] [varchar] (20) COLLATE Latin1_General_CI_AS NULL &#xA;) ON [PRIMARY]&#xA;GO&#xA;&#xA;ALTER TABLE [dbo].[BSESSImport] WITH NOCHECK ADD &#xA; CONSTRAINT [PK_BSESSImport] PRIMARY KEY  CLUSTERED &#xA; (&#xA;  [RBSE]&#xA; )  ON [PRIMARY] &#xA;GO&#xA;&#xA; CREATE  INDEX [IX_BSESSImport_NotificationDate] ON [dbo].[BSESSImport]([NotificationDate]) ON [PRIMARY]&#xA;GO&#xA;&#xA; CREATE  INDEX [IX_BSESSImport_Eartag] ON [dbo].[BSESSImport]([Eartag]) ON [PRIMARY]&#xA;GO&#xA;&#xA; CREATE  INDEX [IX_BSESSImport_TestGroupDerivedSurvey] ON [dbo].[BSESSImport]([TestGroupDerivedSurvey]) ON [PRIMARY]&#xA;GO&#xA;&#xA;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
